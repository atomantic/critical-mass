# Critical Mass — gateway/UI/script environment variables
# Copy this file to .env and fill in values before starting the server.
# Note: engine process wrapper variables (e.g. EXCHANGE_NAME, EXCHANGE_IPC_PORT)
# supplied at runtime are not exhaustively documented here.

# ── Server ─────────────────────────────────────────────────────────────────────

# TCP port the Express/Socket.IO gateway listens on (default: 5563)
PORT=5563

# Comma-separated list of allowed CORS origins (default: http://localhost:5563,http://localhost:5564)
# CORS_ORIGINS=http://localhost:5563,http://localhost:5564

# ── IPC ports (gateway ↔ engine) ───────────────────────────────────────────────

# Port the Coinbase engine IPC server listens on (default: 5570)
COINBASE_IPC_PORT=5570

# Port the Gemini engine IPC server listens on (default: 5571)
GEMINI_IPC_PORT=5571

# Port the Crypto.com engine IPC server listens on (default: 5574)
CRYPTOCOM_IPC_PORT=5574

# ── Admin UI (Vite dev server) ──────────────────────────────────────────────────

# Port the Vite dev server listens on (default: 5564)
VITE_PORT=5564

# Gateway API port Vite proxies /api requests to (default: 5563)
VITE_API_PORT=5563

# ── Scripts ────────────────────────────────────────────────────────────────────

# Gateway base URL used by utility scripts (default: http://localhost:5563)
GATEWAY_URL=http://localhost:5563
