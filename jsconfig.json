{
  "compilerOptions": {
    "checkJs": true,
    "strict": false,
    "noEmit": true,
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "*": ["*"]
    }
  },
  "include": [
    "src/**/*.js",
    "server.js",
    "index.js"
  ],
  "exclude": [
    "node_modules",
    "admin"
  ]
}
