{
  "name": "critical-mass",
  "version": "2.19.2",
  "description": "Multi-exchange BTC accumulation engine with celestial position management",
  "main": "index.js",
  "scripts": {
    "start": "pm2 delete ecosystem.config.cjs 2>/dev/null; for p in 5563 5564 5570 5571 5572 5573 5574; do lsof -i :$p -sTCP:LISTEN -t 2>/dev/null | xargs kill -9 2>/dev/null; done; sleep 1; pm2 start ecosystem.config.cjs && pm2 save",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "VITE_API_PORT=5563 nodemon server.js",
    "dev:ui": "cd admin && VITE_PORT=5564 VITE_API_PORT=5563 npm run dev",
    "build": "cd admin && npm run build",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs critical-mass",
    "pm2:status": "pm2 status",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "cli": "node index.js",
    "cli:status": "node index.js status",
    "cli:debug": "node index.js debug",
    "admin:install": "cd admin && npm install",
    "install:all": "npm install && cd admin && npm install",
    "test": "node --test 'tests/**/*.test.js'"
  },
  "keywords": [
    "coinbase",
    "gemini",
    "dca",
    "trading",
    "btc",
    "usdc",
    "portos",
    "critical-mass"
  ],
  "author": "Adam Eivy (@antic|@atomantic)",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "json-bigint": "^1.0.0",
    "jsonwebtoken": "^9.0.2",
    "portos-ai-toolkit": "^0.5.0",
    "socket.io": "^4.8.2",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  }
}
